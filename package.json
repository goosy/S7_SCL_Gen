{
    "name": "s7-scl-gen",
    "version": "1.20.2",
    "type": "module",
    "description": "S7 PLC SCL 代码自动生成",
    "main": "/lib/index.js",
    "exports": {
        ".": [
            {
                "import": "./lib/index.js"
            },
            "./lib/index.js"
        ]
    },
    "engines": {
        "node": ">=21.2.0"
    },
    "dependencies": {
        "iconv-lite": "^0.6.3",
        "nodemon": "^3.1.14"
    },
    "devDependencies": {
        "globby": "^13.2.2",
        "gooconverter": "^1.1.0",
        "matcher": "^5.0.0",
        "mri": "^1.2.0",
        "rimraf": "^6.1.3",
        "rolldown": "1.1.1",
        "yaml": "^2.9.0"
    },
    "directories": {
        "conf": "example",
        "lib": "lib"
    },
    "bin": {
        "s7scl": "./lib/cli.js"
    },
    "scripts": {
        "clean": "rimraf -g ./example/*/ ./lib ./test/dist",
        "dev": "rimraf -g ./example/*/ && node ./dev.js",
        "build": "node ./build.js",
        "prepublish": "pnpm clean && pnpm build",
        "watch": "nodemon ./build.js",
        "test": "node --test"
    },
    "keywords": [
        "modbusTCP",
        "SCL",
        "S7"
    ],
    "author": "goosy.jo@gmail.com",
    "license": "MIT",
    "packageManager": "pnpm@11.7.0"
}
